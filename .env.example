# ── Required ──────────────────────────────────────────────────────────────────

# Qwen API — get your key at https://dashscope.console.aliyun.com/
QWEN_API_KEY=

# ── Optional ──────────────────────────────────────────────────────────────────

# Qwen base URL. Defaults to US region if unset.
# US region:     https://dashscope-us.aliyuncs.com/compatible-mode/v1
# International: https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_BASE_URL=https://dashscope-us.aliyuncs.com/compatible-mode/v1

# MongoDB connection string. OPTIONAL — leave blank to run without caching or
# history. Atlas free tier: https://www.mongodb.com/cloud/atlas/register
# Local: mongodb://localhost:27017/terms-analyzer
MONGODB_URI=

# Public site URL — used for SEO (canonical URLs, Open Graph, sitemap, robots.txt).
# OPTIONAL on Vercel: auto-detected from VERCEL_PROJECT_PRODUCTION_URL / VERCEL_URL.
# Set this only for a custom domain or when running locally.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
