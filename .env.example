# Qwen API — get your key at https://dashscope.console.aliyun.com/
QWEN_API_KEY=

# Base URL options:
# US region (default): https://dashscope-us.aliyuncs.com/compatible-mode/v1
# International:       https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_BASE_URL=https://dashscope-us.aliyuncs.com/compatible-mode/v1

# MongoDB — Atlas connection string or local: mongodb://localhost:27017/terms-analyzer
MONGODB_URI=

# Public site URL — used for SEO (canonical URLs, Open Graph, sitemap, robots.txt)
# Set this to your production domain once deployed (e.g. https://your-project.web.app)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
